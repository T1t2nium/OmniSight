# 环境配置
# 复制此文件为 .env 并填入实际值

# AI 模型提供商: "ollama" (本地) 或 "gemini" (云端)
AI_PROVIDER=ollama

# Ollama 配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b

# Google Gemini 配置（仅在 AI_PROVIDER=gemini 时需要）
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-live-preview

# 语音识别配置
WHISPER_MODEL=small
WHISPER_LANGUAGE=zh

# 服务器配置
WS_HOST=0.0.0.0
WS_PORT=8000

# 视频配置
MAX_FPS=4
JPEG_QUALITY=70
FRAME_MAX_WIDTH=640
FRAME_MAX_HEIGHT=480
# VISION_ENABLED=true  # 设为 false 关闭视觉，纯文字对话（CPU 下速度快很多）

# TTS 配置
# "sherpa"  = 本地 sherpa-onnx TTS（默认，matcha-icefall-zh-baker 中文女声）
# "piper"   = 本地 Piper TTS（后备选项）
# "browser" = 浏览器 SpeechSynthesis API（无需额外配置）
TTS_BACKEND=sherpa

# sherpa-onnx TTS 配置（默认 TTS 引擎，仅 TTS_BACKEND=sherpa 时需要）
# 下载模型: 运行 scripts/download-sherpa-tts.ps1
# 模型来源: https://github.com/k2-fsa/sherpa-onnx/releases/tag/tts-models
# 模型: matcha-icefall-zh-baker (73 MB, 22050 Hz, Apache 2.0)
SHERPA_MODEL_DIR=
SHERPA_SPEED=1.0
SHERPA_NUM_THREADS=4

# Piper TTS 配置（后备选项，仅 TTS_BACKEND=piper 时需要）
# 下载 piper: https://github.com/rhasspy/piper/releases
# 下载语音模型: https://huggingface.co/rhasspy/piper-voices
# 推荐中文: zh_CN-huayan-medium, 英文: en_US-lessac-medium
PIPER_EXECUTABLE=piper
PIPER_MODEL=
PIPER_MODEL_CONFIG=
PIPER_SPEAKER=

# ---- PR 5: 健壮性配置 ----

# WebSocket 心跳
WS_PING_INTERVAL=30   # 服务器 ping 间隔（秒）
WS_PING_TIMEOUT=10    # 等待 pong 的超时（秒）

# 会话管理
SESSION_IDLE_TIMEOUT=300  # 5 分钟无活动自动清理会话

# 运动检测（跳过无变化帧减少 AI 调用）
MOTION_DETECTION_ENABLED=true
MOTION_THRESHOLD=15.0  # 像素差异均值阈值

# 环境配置
# 复制此文件为 .env 并填入实际值

# AI 模型提供商: "ollama" (本地) 或 "gemini" (云端)
AI_PROVIDER=ollama

# Ollama 配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b

# Google Gemini 配置（仅在 AI_PROVIDER=gemini 时需要）
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-live-preview

# 语音识别配置
WHISPER_MODEL=small
WHISPER_LANGUAGE=zh

# 服务器配置
WS_HOST=0.0.0.0
WS_PORT=8000

# 视频配置
MAX_FPS=4
JPEG_QUALITY=70
FRAME_MAX_WIDTH=640
FRAME_MAX_HEIGHT=480
# VISION_ENABLED=true  # 设为 false 关闭视觉，纯文字对话（CPU 下速度快很多）

# TTS 配置
# "browser" = 浏览器 SpeechSynthesis API（无需额外配置）
# "piper"   = 本地 Piper TTS（需下载语音模型，更自然流畅）
TTS_BACKEND=piper

# Piper TTS 配置（仅 TTS_BACKEND=piper 时需要）
# 下载 piper: https://github.com/rhasspy/piper/releases
# 下载语音模型: https://huggingface.co/rhasspy/piper-voices
# 推荐中文: zh_CN-huayan-medium, 英文: en_US-lessac-medium
PIPER_EXECUTABLE=piper
PIPER_MODEL=
PIPER_MODEL_CONFIG=
PIPER_SPEAKER=
